# 微信账号选择
# 只有一个登录账号时可留空。
CODEX_WECHAT_ACCOUNT_ID=

# 微信桥接服务地址
CODEX_WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
CODEX_WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c
CODEX_WECHAT_QR_BOT_TYPE=3

# 允许控制本机 Codex 的微信用户 ID
CODEX_WECHAT_ALLOWED_USER_IDS=

# 默认工作区
CODEX_WECHAT_DEFAULT_WORKSPACE=

# 允许绑定的工作区白名单
CODEX_WECHAT_WORKSPACE_ALLOWLIST=

# 默认 Codex 参数
CODEX_WECHAT_DEFAULT_CODEX_MODEL=
CODEX_WECHAT_DEFAULT_CODEX_EFFORT=
CODEX_WECHAT_DEFAULT_CODEX_ACCESS_MODE=default

# Codex 连接方式
CODEX_WECHAT_CODEX_ENDPOINT=
CODEX_WECHAT_CODEX_COMMAND=

# 运行行为
CODEX_WECHAT_ENABLE_TYPING=true
CODEX_WECHAT_DEFAULT_WORKSPACE_ID=default
CODEX_WECHAT_AUTOSTART_POLL_MS=10000

# 本地状态目录
CODEX_WECHAT_STATE_DIR=
CODEX_WECHAT_SESSIONS_FILE=
CODEX_WECHAT_SYNC_BUFFER_DIR=

# Optional: launch VSCode on start and let the Codex plugin/session come up there
CODEX_WECHAT_PROXY_URL=
CODEX_WECHAT_VSCODE_LAUNCH_ON_START=false
CODEX_WECHAT_VSCODE_COMMAND=
CODEX_WECHAT_VSCODE_KILL_BEFORE_LAUNCH=false

# Endpoint-only mode:
# Set CODEX_WECHAT_CODEX_ENDPOINT to a ws:// or wss:// URL exposed by your Codex/VSCode environment.
# Leave CODEX_WECHAT_CODEX_COMMAND empty so the app never tries to spawn local codex.
